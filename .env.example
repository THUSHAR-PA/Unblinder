# Groq API key — powers the scene analyzer, weather report, and fused guidance briefing.
# Get one at https://console.groq.com/keys
# Copy this file to .env and fill in the value.
GROQ_API_KEY=

# Fireworks API key — OPTIONAL. Without it everything still works, but the scene
# summary and the voice assistant only ever see YOLO's 80 COCO class names, never
# the image itself. With it, the real frame goes to a vision-language model, which
# can see potholes, kerbs, steps and puddles, and can read signs aloud.
# Get one at https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# Must be a model with supports_image_input=true — check /v1/models for your account.
# Most of the catalogue is text-only and will silently ignore the image rather than
# error, which fails in the worst way: a confident answer about a photo it never saw.
# (kimi-k2p5 also advertises vision but currently returns HTTP 500.)
FIREWORKS_VLM_MODEL=accounts/fireworks/models/kimi-k2p6

# Seconds between VLM calls while the camera is streaming. This is the only knob
# that meaningfully moves cost. No calls are made at all when no camera is attached.
VLM_INTERVAL_S=6
